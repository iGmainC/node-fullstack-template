{
  "name": "node-fullstack-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter @workspace/frontend dev",
    "build": "bun run --filter @workspace/frontend build",
    "typecheck": "bun run --filter @workspace/backend typecheck && bun run --filter @workspace/frontend typecheck",
    "lint": "eslint .",
    "preview": "bun run --filter @workspace/frontend preview"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.9",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "hono": "^4.11.9",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
