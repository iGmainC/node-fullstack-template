{
	"name": "node-fullstack-template",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev": "bun --env-file=.env vite --config vite.config.ts",
		"clean": "rm -rf dist",
		"build": "bun vite build && bun build ./apps/backend/server.ts --target node --format esm --outfile ./dist/backend/server.js",
		"format": "biome format --write .",
		"lint": "eslint ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@eslint/js": "^9.39.1",
		"@hono/node-server": "^1.19.9",
		"@igmainc/vite-plugin-hono-dev": "^0.1.2",
		"@tanstack/router-plugin": "^1.162.1",
		"@types/node": "^25.3.0",
		"@types/pg": "^8.16.0",
		"@vitejs/plugin-react": "^5.1.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"hono": "^4.11.9",
		"prisma": "^7.4.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.48.0",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^5.1.4"
	},
	"dependencies": {
		"@hono/trpc-server": "^0.4.2",
		"@prisma/adapter-pg": "^7.4.1",
		"@prisma/client": "^7.4.1",
		"@t3-oss/env-core": "^0.13.10",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-router": "^1.162.1",
		"@tanstack/react-router-devtools": "^1.162.1",
		"@trpc/client": "^11.10.0",
		"@trpc/server": "^11.10.0",
		"@types/react-dom": "^19.2.3",
		"better-auth": "^1.4.18",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.3.1",
		"i18next": "^25.8.13",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-chained-backend": "^5.0.2",
		"i18next-http-backend": "^3.0.2",
		"i18next-localstorage-backend": "^4.3.1",
		"install": "^0.13.0",
		"lucide-react": "^0.575.0",
		"pg": "^8.18.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-i18next": "^16.5.4",
		"shadcn": "^3.8.5",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	}
}
