{
	"name": "node-fullstack-template",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev": "bun run --filter @workspace/frontend dev",
		"clean": "rm -rf dist",
		"build": "bun run clean && bun run --filter @workspace/backend build && bun run --filter @workspace/frontend build",
		"typecheck": "bun run --filter @workspace/backend typecheck && bun run --filter @workspace/frontend typecheck",
		"format": "biome format --write .",
		"lint": "eslint .",
		"preview": "bun run --filter @workspace/frontend preview"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@eslint/js": "^9.39.1",
		"@hono/node-server": "^1.19.9",
		"@tanstack/router-plugin": "^1.162.1",
		"@types/node": "^25.3.0",
		"@types/pg": "^8.16.0",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"hono": "^4.11.9",
		"prisma": "^7.4.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.48.0"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.4.1",
		"@prisma/client": "^7.4.1",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-router": "^1.162.1",
		"@tanstack/react-router-devtools": "^1.162.1",
		"dotenv": "^17.3.1",
		"pg": "^8.18.0",
		"tailwindcss": "^4.1.18"
	}
}
