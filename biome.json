{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"apps/*/src/**",
			"apps/*/*.json",
			"apps/*/*.ts",
			"apps/*/*.tsx",
			"package/**/*.ts",
			"package/**/*.tsx",
			"*.json",
			"*.js",
			"*.ts",
			"!!**/node_modules",
			"!!**/dist",
			"!!**/.tanstack"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"indentWidth": 2,
			"indentStyle": "space"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
